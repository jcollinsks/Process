{
  "$schema": "https://developer.microsoft.com/json-schemas/fabric/item/report/definition/visualContainer/1.0.0/schema.json",
  "name": "pieRunStatus",
  "position": {
    "x": 50,
    "y": 200,
    "z": 0,
    "width": 500,
    "height": 350,
    "tabOrder": 5
  },
  "visual": {
    "visualType": "donutChart",
    "drillFilterOtherVisuals": true,
    "query": {
      "queryState": {
        "Category": {
          "projections": [
            {
              "field": {
                "Column": {
                  "Expression": {
                    "SourceRef": {
                      "Entity": "FlowRuns"
                    }
                  },
                  "Property": "StatusCategory"
                }
              },
              "queryRef": "FlowRuns.StatusCategory",
              "nativeQueryRef": "StatusCategory",
              "active": true
            }
          ]
        },
        "Y": {
          "projections": [
            {
              "field": {
                "Measure": {
                  "Expression": {
                    "SourceRef": {
                      "Entity": "_Measures"
                    }
                  },
                  "Property": "Total Flow Runs"
                }
              },
              "queryRef": "_Measures.Total Flow Runs",
              "nativeQueryRef": "Total Flow Runs"
            }
          ]
        }
      }
    }
  }
}