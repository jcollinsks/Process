{
  "$schema": "https://developer.microsoft.com/json-schemas/fabric/item/report/definition/visualContainer/1.0.0/schema.json",
  "name": "barRiskByCategory",
  "position": {
    "x": 20,
    "y": 200,
    "z": 0,
    "width": 600,
    "height": 300,
    "tabOrder": 4
  },
  "visual": {
    "visualType": "barChart",
    "drillFilterOtherVisuals": true,
    "query": {
      "queryState": {
        "Category": {
          "projections": [
            {
              "field": {
                "Column": {
                  "Expression": {
                    "SourceRef": {
                      "Entity": "ProcessConfiguration"
                    }
                  },
                  "Property": "RiskCategory"
                }
              },
              "queryRef": "ProcessConfiguration.RiskCategory",
              "nativeQueryRef": "RiskCategory",
              "active": true
            }
          ]
        },
        "Y": {
          "projections": [
            {
              "field": {
                "Measure": {
                  "Expression": {
                    "SourceRef": {
                      "Entity": "_Measures"
                    }
                  },
                  "Property": "Risk Reduction Value"
                }
              },
              "queryRef": "_Measures.Risk Reduction Value",
              "nativeQueryRef": "Risk Reduction Value"
            }
          ]
        }
      }
    }
  }
}