{
  "$schema": "https://developer.microsoft.com/json-schemas/fabric/item/report/definition/visualContainer/1.0.0/schema.json",
  "name": "barFailureByFlow",
  "position": {
    "x": 640,
    "y": 200,
    "z": 0,
    "width": 620,
    "height": 300,
    "tabOrder": 5
  },
  "visual": {
    "visualType": "barChart",
    "drillFilterOtherVisuals": true,
    "query": {
      "queryState": {
        "Category": {
          "projections": [
            {
              "field": {
                "Column": {
                  "Expression": {
                    "SourceRef": {
                      "Entity": "CloudFlows"
                    }
                  },
                  "Property": "FlowName"
                }
              },
              "queryRef": "CloudFlows.FlowName",
              "nativeQueryRef": "FlowName",
              "active": true
            }
          ]
        },
        "Y": {
          "projections": [
            {
              "field": {
                "Measure": {
                  "Expression": {
                    "SourceRef": {
                      "Entity": "_Measures"
                    }
                  },
                  "Property": "Failure Rate"
                }
              },
              "queryRef": "_Measures.Failure Rate",
              "nativeQueryRef": "Failure Rate"
            }
          ]
        }
      }
    }
  }
}