              "queryRef": "FlowRuns.RunHour",
              "nativeQueryRef": "RunHour",
              "active": true
            }
          ]
        },
        "Y": {
          "projections": [
            {
              "field": {
                "Measure": {
                  "Expression": {
                    "SourceRef": {
                      "Entity": "_Measures"
                    }
                  },
                  "Property": "Total Flow Runs"
                }
              },
              "queryRef": "_Measures.Total Flow Runs",
              "nativeQueryRef": "Total Flow Runs"
