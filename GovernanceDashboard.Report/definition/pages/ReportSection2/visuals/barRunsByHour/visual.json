{
  "$schema": "https://developer.microsoft.com/json-schemas/fabric/item/report/definition/visualContainer/1.0.0/schema.json",
  "name": "barRunsByHour",
  "position": {
    "x": 790,
    "y": 60,
    "z": 0,
    "width": 470,
    "height": 300,
    "tabOrder": 1
  },
  "visual": {
