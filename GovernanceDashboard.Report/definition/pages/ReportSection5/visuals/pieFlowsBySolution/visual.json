{
  "$schema": "https://developer.microsoft.com/json-schemas/fabric/item/report/definition/visualContainer/1.0.0/schema.json",
  "name": "pieFlowsBySolution",
  "position": {
    "x": 640,
    "y": 200,
    "z": 0,
    "width": 620,
    "height": 300,
    "tabOrder": 5
  },
  "visual": {
    "visualType": "donutChart",
    "drillFilterOtherVisuals": true,
    "query": {
      "queryState": {
        "Category": {
          "projections": [
            {
              "field": {
                "Column": {
                  "Expression": {
                    "SourceRef": {
                      "Entity": "CloudFlows"
                    }
                  },
                  "Property": "IsInSolution"
                }
              },
              "queryRef": "CloudFlows.IsInSolution",
              "nativeQueryRef": "IsInSolution",
              "active": true
            }
          ]
        },
        "Y": {
          "projections": [
            {
              "field": {
                "Measure": {
                  "Expression": {
                    "SourceRef": {
                      "Entity": "_Measures"
                    }
                  },
                  "Property": "Total Cloud Flows"
                }
              },
              "queryRef": "_Measures.Total Cloud Flows",
              "nativeQueryRef": "Total Cloud Flows"
            }
          ]
        }
      }
    }
  }
}