{
  "name": "Power Automate Governance",
  "dataColors": [
    "#0078D4",
    "#107C10",
    "#FFB900",
    "#D13438",
    "#8764B8",
    "#00B7C3",
    "#FF8C00",
    "#E3008C",
    "#4C6EF5",
    "#00CC6A"
  ],
  "background": "#F3F2F1",
  "foreground": "#323130",
  "tableAccent": "#0078D4",
  "good": "#107C10",
  "neutral": "#FFB900",
  "bad": "#D13438",
  "maximum": "#D13438",
  "center": "#FFB900",
  "minimum": "#107C10",
  "textClasses": {
    "callout": {
      "fontSize": 36,
      "fontFace": "Segoe UI Semibold",
      "color": "#323130"
    },
    "title": {
      "fontSize": 16,
      "fontFace": "Segoe UI Semibold",
      "color": "#323130"
    },
    "header": {
      "fontSize": 13,
      "fontFace": "Segoe UI Semibold",
      "color": "#323130"
    },
    "label": {
      "fontSize": 11,
      "fontFace": "Segoe UI",
      "color": "#605E5C"
    }
  },
  "visualStyles": {
    "*": {
      "*": {
        "background": [
          {
            "color": { "solid": { "color": "#FFFFFF" } },
            "transparency": 0
          }
        ],
        "border": [
          {
            "color": { "solid": { "color": "#E1DFDD" } },
            "show": true
          }
        ],
        "outspacePane": [
          {
            "backgroundColor": { "solid": { "color": "#F3F2F1" } },
            "transparency": 0
          }
        ],
        "visualHeader": [
          {
            "show": false
          }
        ],
        "dropShadow": [
          {
            "show": true,
            "color": { "solid": { "color": "#000000" } },
            "position": "Outer",
            "preset": "BottomRight",
            "transparency": 85
          }
        ]
      }
    },
    "page": {
      "*": {
        "background": [
          {
            "color": { "solid": { "color": "#F3F2F1" } },
            "transparency": 0
          }
        ]
      }
    },
    "card": {
      "*": {
        "labels": [
          {
            "fontSize": 32,
            "fontFamily": "Segoe UI Semibold",
            "color": { "solid": { "color": "#0078D4" } }
          }
        ],
        "categoryLabels": [
          {
            "fontSize": 11,
            "fontFamily": "Segoe UI",
            "color": { "solid": { "color": "#605E5C" } }
          }
        ]
      }
    },
    "pieChart": {
      "*": {
        "legend": [
          {
            "show": true,
            "position": "Bottom",
            "fontSize": 10,
            "fontFamily": "Segoe UI"
          }
        ],
        "labels": [
          {
            "show": true,
            "labelStyle": "Both",
            "fontSize": 10
          }
        ]
      }
    },
    "slicer": {
      "*": {
        "items": [
          {
            "fontSize": 10,
            "fontFamily": "Segoe UI",
            "fontColor": { "solid": { "color": "#323130" } },
            "background": { "solid": { "color": "#FFFFFF" } }
          }
        ],
        "header": [
          {
            "show": true,
            "fontSize": 11,
            "fontFamily": "Segoe UI Semibold",
            "fontColor": { "solid": { "color": "#323130" } }
          }
        ]
      }
    },
    "lineChart": {
      "*": {
        "lineStyles": [
          {
            "strokeWidth": 2
          }
        ],
        "categoryAxis": [
          {
            "fontSize": 9,
            "fontFamily": "Segoe UI"
          }
        ],
        "valueAxis": [
          {
            "fontSize": 9,
            "fontFamily": "Segoe UI"
          }
        ]
      }
    }
  }
}
